class Solution {
    public int[] distributeCandies(int candies, int num_people) {
        int[] res = new int[num_people];
        int give = 1;
        int i = 0;

        while (candies > 0) {
            int val = Math.min(give, candies);
            res[i] += val;

            candies -= val;
            give++;
            i = (i + 1) % num_people;
        }

        return res;
    }
}
